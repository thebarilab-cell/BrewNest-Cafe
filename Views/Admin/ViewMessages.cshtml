@model IEnumerable<BrewNestCafe.Models.ContactMessage>
@{
    ViewData["Title"] = "View Messages";
}

<div class="container-fluid py-4">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h2">Customer Messages</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a asp-action="Dashboard">Dashboard</a></li>
                            <li class="breadcrumb-item active">Messages</li>
                        </ol>
                    </nav>
                </div>
                <div>
                    <span class="badge bg-warning me-2">
                        Unread: @Model?.Count(m => !m.IsRead)
                    </span>
                    <span class="badge bg-success">
                        Total: @Model?.Count()
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Success Message -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Messages Cards -->
    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var message in Model)
            {
                <div class="col-lg-6 col-xl-4 mb-4">
                    <div class="card message-card @(message.IsRead ? "border-left-success" : "border-left-warning")">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">@message.Name</h6>
                                <small class="text-muted">@message.Email</small>
                            </div>
                            <div class="d-flex">
                                @if (!message.IsRead)
                                {
                                    <form asp-action="MarkAsRead" method="post" class="me-2">
                                        <input type="hidden" name="id" value="@message.Id" />
                                        <button type="submit" class="btn btn-sm btn-success" title="Mark as read">
                                            <i class="bi bi-check-circle"></i>
                                        </button>
                                    </form>
                                }
                                <form asp-action="DeleteMessage" method="post">
                                    <input type="hidden" name="id" value="@message.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger"
                                            onclick="return confirm('Are you sure you want to delete this message?')"
                                            title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@message.Message</p>

                            <div class="message-meta mt-3 pt-3 border-top">
                                <div class="row">
                                    <div class="col-6">
                                        <small class="text-muted">
                                            <i class="bi bi-calendar me-1"></i>
                                            @message.Date.ToString("MMM dd, yyyy")
                                        </small>
                                    </div>
                                    <div class="col-6 text-end">
                                        <small class="text-muted">
                                            <i class="bi bi-clock me-1"></i>
                                            @message.Date.ToString("hh:mm tt")
                                        </small>
                                    </div>
                                </div>
                                <div class="mt-2">
                                    @if (message.IsRead)
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>Read
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">
                                            <i class="bi bi-clock me-1"></i>Unread
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-transparent">
                            <div class="d-flex justify-content-between">
                                <a href="mailto:@message.Email" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-reply me-1"></i>Reply
                                </a>
                                <button type="button" class="btn btn-sm btn-outline-info copy-email"
                                        data-email="@message.Email">
                                    <i class="bi bi-copy me-1"></i>Copy Email
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="bi bi-envelope display-4 text-muted mb-3 d-block"></i>
                    <h3>No Messages Yet</h3>
                    <p class="text-muted">Customer messages will appear here when they contact you.</p>
                    <a asp-action="Dashboard" class="btn btn-primary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<!-- Message Details Modal -->
<div class="modal fade" id="messageModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Message Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="messageModalBody">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

<style>
    .message-card {
        border: none;
        border-radius: 10px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.08);
        transition: all 0.3s;
        height: 100%;
    }

        .message-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }

    .border-left-success {
        border-left: 4px solid #28a745 !important;
    }

    .border-left-warning {
        border-left: 4px solid #ffc107 !important;
    }

    .card-header {
        background-color: rgba(0,0,0,0.03);
        border-bottom: 1px solid rgba(0,0,0,0.125);
    }

    .message-meta {
        font-size: 0.85rem;
    }

    .badge {
        font-size: 0.8em;
        padding: 0.4em 0.8em;
    }

    .btn-sm {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
    }

    /* Responsive Design */
    @@media (max-width: 768px) {
        .col-lg-6 {
            margin-bottom: 1rem;
        }

        .card-body {
            padding: 1rem;
        }

        .card-footer {
            padding: 0.75rem;
        }
    }
</style>

<script>
    // Copy email to clipboard
    document.querySelectorAll('.copy-email').forEach(button => {
        button.addEventListener('click', function() {
            const email = this.dataset.email;

            navigator.clipboard.writeText(email).then(() => {
                // Show success message
                const originalText = this.innerHTML;
                this.innerHTML = '<i class="bi bi-check me-1"></i>Copied!';
                this.classList.remove('btn-outline-info');
                this.classList.add('btn-success');

                setTimeout(() => {
                    this.innerHTML = originalText;
                    this.classList.remove('btn-success');
                    this.classList.add('btn-outline-info');
                }, 2000);
            }).catch(err => {
                alert('Failed to copy email: ' + err);
            });
        });
    });

    // Filter messages
    function filterMessages(status) {
        const cards = document.querySelectorAll('.message-card');
        cards.forEach(card => {
            const isRead = card.classList.contains('border-left-success');

            if (status === 'all' ||
                (status === 'read' && isRead) ||
                (status === 'unread' && !isRead)) {
                card.parentElement.style.display = 'block';
            } else {
                card.parentElement.style.display = 'none';
            }
        });
    }

    // View message details
    function viewMessageDetails(messageId) {
        fetch(`/Admin/GetMessage/${messageId}`)
            .then(response => response.text())
            .then(html => {
                document.getElementById('messageModalBody').innerHTML = html;
                new bootstrap.Modal(document.getElementById('messageModal')).show();
            });
    }

    // Add filter buttons dynamically
    document.addEventListener('DOMContentLoaded', function() {
        const headerDiv = document.querySelector('.row.mb-4 .col-12 .d-flex');

        if (headerDiv) {
            const filterHtml = `
                <div class="btn-group btn-group-sm" role="group">
                    <button type="button" class="btn btn-outline-primary" onclick="filterMessages('all')">All</button>
                    <button type="button" class="btn btn-outline-success" onclick="filterMessages('read')">Read</button>
                    <button type="button" class="btn btn-outline-warning" onclick="filterMessages('unread')">Unread</button>
                </div>
            `;

            headerDiv.innerHTML += filterHtml;
        }
    });
</script>