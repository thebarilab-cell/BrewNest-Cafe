@{
    ViewData["Title"] = "Access Denied";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <div class="access-denied-card p-5">
                <i class="bi bi-shield-exclamation display-1 text-danger mb-4"></i>
                <h1 class="display-5 fw-bold mb-3">Access Denied</h1>
                <p class="lead mb-4">You do not have permission to access this page.</p>

                <div class="alert alert-warning mb-4">
                    <h5 class="alert-heading">Required Permissions</h5>
                    <p class="mb-0">This page requires administrator privileges. Please contact your system administrator.</p>
                </div>

                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-house-door me-2"></i>Go Home
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Login Again
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .access-denied-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
    }
</style>