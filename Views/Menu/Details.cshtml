@model BrewNestCafe.Models.MenuItem
@{
    ViewData["Title"] = Model.Name;
}

<div class="container py-5">
    <div class="row">
        <!-- Back Button -->
        <div class="col-12 mb-4">
            <a asp-action="Index" class="btn btn-outline-primary">
                <i class="bi bi-arrow-left me-2"></i>Back to Menu
            </a>
        </div>

        <!-- Menu Item Details -->
        <div class="col-lg-6 mb-4">
            <div class="menu-detail-image">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded">
                }
                else
                {
                    <div class="no-image-placeholder bg-secondary rounded d-flex align-items-center justify-content-center"
                         style="height: 400px;">
                        <i class="bi bi-cup-hot text-white display-1"></i>
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-6">
            <div class="menu-detail-info">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <h1 class="mb-0">@Model.Name</h1>
                    <span class="badge bg-primary fs-6">@Model.Category?.Name</span>
                </div>

                <div class="rating mb-3">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi bi-star-fill text-warning"></i>
                    }
                    <span class="ms-2">(4.5/5)</span>
                </div>

                <div class="price-section mb-4">
                    <h2 class="text-primary">$@Model.Price.ToString("0.00")</h2>
                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Currently Unavailable</span>
                    }
                </div>

                <div class="description mb-4">
                    <h4>Description</h4>
                    <p class="lead">@Model.Description</p>
                </div>

                <div class="nutrition-info mb-4">
                    <h4>Ingredients</h4>
                    <p>Freshly brewed coffee, steamed milk, chocolate syrup, whipped cream</p>
                </div>

                <div class="action-buttons">
                    <button class="btn btn-primary btn-lg me-3">
                        <i class="bi bi-cart-plus me-2"></i>Add to Order
                    </button>
                    <button class="btn btn-outline-primary btn-lg">
                        <i class="bi bi-heart me-2"></i>Add to Favorites
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Related Items -->
    <div class="row mt-5">
        <div class="col-12">
            <h3 class="mb-4">You May Also Like</h3>
            <div class="row">
                <!-- Related items would be loaded here -->
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body text-center">
                            <i class="bi bi-cup-hot display-4 text-muted mb-3"></i>
                            <h5>Related Item</h5>
                            <p class="text-muted">Coming soon</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .menu-detail-image img {
        width: 100%;
        height: 400px;
        object-fit: cover;
        border-radius: 10px;
    }

    .no-image-placeholder {
        border-radius: 10px;
    }

    .menu-detail-info {
        padding: 20px;
    }

    .rating {
        font-size: 1.2rem;
    }

    .price-section {
        padding: 20px;
        background: #f8f9fa;
        border-radius: 10px;
    }

    .nutrition-info {
        padding: 15px;
        background: #f8f9fa;
        border-radius: 10px;
    }

    .action-buttons {
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #eee;
    }
</style>

<script>
    // Add to cart functionality
    document.querySelector('.btn-primary').addEventListener('click', function() {
        const itemName = '@Model.Name';
        const itemPrice = @Model.Price;

        // Add to cart logic here
        alert(`Added ${itemName} to cart!`);
    });
</script>